# Mesa — environment variables
# Copy to `.env.local` (gitignored) for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for Preview + Production.
# NOTE: .env* files live in the PROJECT ROOT, not in /src (Next.js only loads
# them from the parent of /src).

# --- Supabase ---------------------------------------------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key — server-only, NEVER prefixed NEXT_PUBLIC_ and never sent to
# the browser. Used by the webhook + seed/admin paths only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- PayMongo (billing) -----------------------------------------------------
# PayMongo Dashboard → Developers → API Keys (use the TEST keys to start).
PAYMONGO_SECRET_KEY=sk_test_xxx
# Webhook signing secret from PayMongo Dashboard → Developers → Webhooks.
PAYMONGO_WEBHOOK_SECRET=whsk_xxx

# --- App --------------------------------------------------------------------
# Absolute base URL of the deployment (used for auth redirects & webhook URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sentry (error monitoring) ----------------------------------------------
# Sentry → Settings → Projects → [project] → Client Keys (DSN). Same DSN for
# both — public/client and server/edge are separate inits, not separate keys.
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://xxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# Sentry org/project slugs (from the project URL) — needed for source map upload.
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
# Sentry → Settings → Auth Tokens. Build-time secret — set in CI/hosting env
# only, never commit to .env.local if this repo is ever made public.
SENTRY_AUTH_TOKEN=sntrys_xxx
